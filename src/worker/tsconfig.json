{
    "compilerOptions": {
        "outDir": "../../dist/worker",
        "noImplicitAny": true,
        "strict": true,
        "noImplicitReturns": true,
        "noImplicitThis": true,
        "strictNullChecks": true,
        "removeComments": false,
        "sourceMap": true,
        "module": "es2020",
        "target": "es2020",
        "lib": [
            "webworker",
            "dom",
            "es2020",
            "es2020.promise"
        ],
        "moduleResolution": "node",
        "esModuleInterop": true,
        "skipLibCheck": true
    },
    "include": [
        "./*.ts"
    ]
}
